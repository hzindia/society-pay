generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  RESIDENT
  ADMIN
  TREASURER
}

enum PaymentStatus {
  CREATED
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  phone         String?
  passwordHash  String
  name          String
  flatNumber    String
  wing          String?
  role          Role      @default(RESIDENT)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  payments      Payment[]

  @@index([flatNumber])
  @@index([role])
}

model Payment {
  id                  String        @id @default(cuid())
  transactionId       String        @unique   // Human-readable: SOC-XXXX-XXXX
  userId              String
  user                User          @relation(fields: [userId], references: [id])

  // Payment details
  paymentType         String        // "Monthly Maintenance", "Parking", etc.
  description         String?
  baseAmount          Float         // Amount before surcharges (in INR)
  paymentMethod       String        // "credit_card", "upi", etc.
  surchargeRate       Float         @default(0)  // e.g. 0.02 for 2%
  surchargeAmount     Float         @default(0)
  gstOnSurcharge      Float         @default(0)
  totalAmount         Float         // Final amount charged

  // Razorpay fields
  razorpayOrderId     String?       @unique
  razorpayPaymentId   String?       @unique
  razorpaySignature   String?

  // Status
  status              PaymentStatus @default(CREATED)
  paidAt              DateTime?
  failureReason       String?

  // Idempotency & lifecycle
  idempotencyKey      String?       @unique   // Client-generated key to prevent duplicate orders
  expiresAt           DateTime?               // Razorpay order expiry (30 min from creation)
  emailSent           Boolean       @default(false)
  emailAttempts       Int           @default(0)

  // Metadata
  receiptUrl          String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  events              PaymentEvent[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([paymentType])
  @@index([razorpayOrderId])
}

// Per-step state log — every status transition is recorded with source and context
model PaymentEvent {
  id          String         @id @default(cuid())
  paymentId   String
  payment     Payment        @relation(fields: [paymentId], references: [id])
  fromStatus  PaymentStatus?
  toStatus    PaymentStatus
  source      String         // "client_create", "client_verify", "webhook", "reconcile"
  metadata    Json?
  createdAt   DateTime       @default(now())

  @@index([paymentId])
  @@index([createdAt])
}

// Webhook deduplication — prevents reprocessing Razorpay retries
model WebhookEvent {
  id              String    @id @default(cuid())
  razorpayEventId String?   @unique   // Razorpay's own event ID (from payload.id)
  eventType       String
  orderId         String?
  processed       Boolean   @default(false)
  processedAt     DateTime?
  error           String?
  payload         Json
  createdAt       DateTime  @default(now())

  @@index([orderId])
  @@index([createdAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String   // "payment.created", "payment.captured", "user.login", etc.
  entityType  String?  // "payment", "user"
  entityId    String?
  metadata    Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}
